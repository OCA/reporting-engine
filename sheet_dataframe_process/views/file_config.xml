<odoo>

<record id="file_config_form" model="ir.ui.view">
    <field name="model">file.config</field>
    <field name="arch" type="xml">
        <form>
            <header>
<button
                        name="populate_match_lines"
                        string="Populate"
                        type="object"
                        help="Populate matching lines with partners"
                    />
<!--
                <button
                        name="%(sheet_dataframe_transient_action)d"
                        type="action"
                        string="Import"
                        context="{'default_partner_id': partner_id}"
                    />
                     -->
            </header>
            <sheet>
                <group>
                    <group>
                        <field name="model_id" />
                        <field name="action" widget="radio" />
                    </group>
                    <group>
                        <field name="code" />
                        <field name="partner_ids" widget="many2many_tags" />
                    </group>
                    <separator string="Odoo field rules" />
                   <field name="field_ids" />
                    <separator string="Matching file fields" />
                   <field name="field_match_ids" />
                </group>
            </sheet>
            <chatter />
        </form>
    </field>
</record>

<record id="file_config_tree" model="ir.ui.view">
    <field name="model">file.config</field>
    <field name="arch" type="xml">
        <list>
            <field name="model_id" />
            <field name="code" />
            <field name="action" />
            <field name="partner_ids" />
        </list>
    </field>
</record>

<record id="file_config_search" model="ir.ui.view">
    <field name="model">file.config</field>
    <field name="arch" type="xml">
        <search>
            <field name="model_id" />
            <field name="action" />
            <field name="code" />
            <group expand="0" string="Group By">
                <filter
                        string="Model"
                        name="model_id"
                        domain="[]"
                        context="{'group_by': 'model_id'}"
                    />
                <filter
                        string="Action"
                        name="action"
                        domain="[]"
                        context="{'group_by': 'action'}"
                    />
            </group>
        </search>
    </field>
</record>

<record id="action_file_config" model="ir.actions.act_window">
    <field name="name">Configuration</field>
    <field name="res_model">file.config</field>
    <field name="view_mode">list,form</field>
    <field name="path">file-config</field>
</record>

</odoo>
